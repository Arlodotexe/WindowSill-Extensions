<?xml version="1.0" encoding="utf-8" ?>
<api:SillPopupContent
    x:Class="WindowSill.ShortTermReminder.Views.NewReminderPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="350"
    Opening="OnOpening">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content area -->
        <Grid
            Grid.Row="0"
            Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,12"
                FontSize="20"
                FontWeight="SemiBold"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                MaxLines="2"
                TextWrapping="Wrap"
                api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/Title" />

            <StackPanel
                Grid.Row="1"
                Spacing="12">

                <TextBox
                    x:Name="ReminderTextBox"
                    TabIndex="0"
                    api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/ReminderTextBox"
                    Text="{x:Bind ViewModel.ReminderText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    KeyDown="ReminderTextBox_KeyDown" />

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8">

                    <TextBlock
                        VerticalAlignment="Center"
                        api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/InHowLong" />

                    <NumberBox
                        x:Name="MinutesNumberBox"
                        TabIndex="1"
                        Minimum="1"
                        Maximum="90"
                        SpinButtonPlacementMode="Compact"
                        SmallChange="5"
                        LargeChange="10"
                        Value="{x:Bind ViewModel.Minutes, Mode=TwoWay}"
                        KeyDown="ReminderTextBox_KeyDown" />

                    <TextBlock
                        VerticalAlignment="Center"
                        api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/Minutes" />
                </StackPanel>

                <TextBlock
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{x:Bind ViewModel.ExactTimeText, Mode=OneWay}" />
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Border
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            XYFocusKeyboardNavigation="Enabled"
            Padding="24"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">

            <Grid
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="1"
                    Style="{ThemeResource LargeAccentButtonStyle}"
                    ElementSoundMode="FocusOnly"
                    api:Uids.Uid="/WindowSill.ShortTermReminder/NewReminderPopup/OkButton"
                    Command="{x:Bind ViewModel.OkCommand}" />
            </Grid>
        </Border>
    </Grid>
</api:SillPopupContent>
