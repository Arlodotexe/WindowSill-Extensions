<?xml version="1.0" encoding="utf-8" ?>
<api:SillPopupContent
    x:Class="WindowSill.ShortTermReminder.Views.ReminderPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:WindowSill.ShortTermReminder.Views"
    mc:Ignorable="d"
    Width="350"
    Opening="OnOpening">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content area -->
        <StackPanel
            Grid.Row="0"
            Padding="24"
            Spacing="12">

            <RichTextBlock
                FontSize="20"
                FontWeight="SemiBold"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                MaxLines="5"
                TextWrapping="Wrap"
                TextTrimming="WordEllipsis"
                views:RichTextBlockLinkBehavior.LinkedText="{x:Bind ViewModel.Reminder.Title, Mode=OneTime}" />

            <TextBlock
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="{x:Bind ViewModel.RemainingTimeText, Mode=OneWay}" />
        </StackPanel>

        <!-- Footer -->
        <Border
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            XYFocusKeyboardNavigation="Enabled"
            Padding="24"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">

            <Button
                ElementSoundMode="FocusOnly"
                HorizontalAlignment="Stretch"
                MinWidth="80"
                Command="{x:Bind ViewModel.DeleteCommand}">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8">
                    <FontIcon
                        FontSize="16"
                        Glyph="&#xE74D;" />
                    <TextBlock
                        api:Uids.Uid="/WindowSill.ShortTermReminder/ReminderSillListViewPopupItem/Delete" />
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</api:SillPopupContent>
