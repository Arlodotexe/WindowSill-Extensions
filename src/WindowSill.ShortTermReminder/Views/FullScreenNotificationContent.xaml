<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowSill.ShortTermReminder.Views.FullScreenNotificationContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:api="using:WindowSill.API"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:WindowSill.ShortTermReminder.Views"
    mc:Ignorable="d">

    <Grid>
        <MediaPlayerElement
            x:Name="BackgroundMediaPlayer"
            AreTransportControlsEnabled="False"
            IsFullWindow="False"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Stretch="None"
            Height="0"
            Width="0"
            Loaded="BackgroundMediaPlayer_Loaded" />

        <Border
            BorderThickness="1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            CornerRadius="{ThemeResource OverlayCornerRadius}"
            Margin="72"
            MaxWidth="1200">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Reminder content -->
                <StackPanel
                    Grid.Row="0"
                    Padding="36,40,36,40"
                    Spacing="16"
                    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
                    <StackPanel.ChildrenTransitions>
                        <EntranceThemeTransition IsStaggeringEnabled="True" />
                    </StackPanel.ChildrenTransitions>

                    <TextBlock
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        HorizontalTextAlignment="Center"
                        HorizontalAlignment="Stretch"
                        CharacterSpacing="200"
                        api:Uids.Uid="/WindowSill.ShortTermReminder/FullScreenNotificationWindow/Title" />

                    <RichTextBlock
                        FontSize="40"
                        FontWeight="SemiBold"
                        MaxLines="5"
                        TextWrapping="WrapWholeWords"
                        TextTrimming="WordEllipsis"
                        HorizontalAlignment="Stretch"
                        TextAlignment="Center"
                        views:RichTextBlockLinkBehavior.LinkedText="{x:Bind ViewModel.ReminderTitle, Mode=OneTime}"
                        views:RichTextBlockLinkBehavior.LinkClickedCommand="{x:Bind ViewModel.OpenLinkAndDismissCommand}" />
                </StackPanel>

                <!-- Actions footer -->
                <Border
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Padding="36,40,36,40"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Center">

                        <Button Command="{x:Bind ViewModel.DismissCommand}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon
                                    FontSize="16"
                                    Glyph="&#xE894;" />
                                <TextBlock
                                    api:Uids.Uid="/WindowSill.ShortTermReminder/FullScreenNotificationWindow/Dismiss" />
                            </StackPanel>
                        </Button>

                        <Button Command="{x:Bind ViewModel.SnoozeCommand}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <FontIcon
                                    FontSize="16"
                                    Glyph="&#xF4BD;" />
                                <TextBlock
                                    api:Uids.Uid="/WindowSill.ShortTermReminder/FullScreenNotificationWindow/Snooze" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
